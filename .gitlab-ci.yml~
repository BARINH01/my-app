stages:
  - build
  - test
  - lint
  - template
  - deploy

variables:
  RELEASE_NAME: my-release
  CHART_PATH: .

maven-build:
  stage: build
  script:
    - cd my-java-app
    - mvn compile
  tags:
    - my-runner

maven-test:
  stage: test
  script:
    - cd my-java-app
    - mvn test
  tags:
    - my-runner

maven-package:
  stage: test
  script:
    - cd my-java-app
    - mvn package
  tags:
    - my-runner

helm-lint:
  stage: lint
  script:
    - helm lint $CHART_PATH
  tags:
    - my-runner

helm-template:
  stage: template
  script:
    - helm template $RELEASE_NAME $CHART_PATH
  tags:
    - my-runner

helm-deploy:
  stage: deploy
  script:
    - helm upgrade --install $RELEASE_NAME $CHART_PATH --reset-values
  tags:
    - my-runner
  only:
    - main
