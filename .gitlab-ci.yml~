stages:
  - build
  - lint
  - template
  - deploy

variables:
  RELEASE_NAME: my-release
  CHART_PATH: .

# Maven build
maven-build:
  stage: build
  script:
    - cd my-java-app
    - mvn compile
  tags:
    - my-runner

# Maven test
maven-test:
  stage: test
  script:
    - cd my-java-app
    - mvn test
  tags:
    - my-runner

# Maven package
maven-package:
  stage: test
  script:
    - cd my-java-app
    - mvn package
  tags:
    - my-runner

# Helm lint
helm-lint:
  stage: lint
  script:
    - helm lint $CHART_PATH
  tags:
    - my-runner

# Helm deploy
helm-deploy:
  stage: deploy
  script:
    - helm upgrade --install $RELEASE_NAME $CHART_PATH --reset-values
  tags:
    - my-runner
  only:
    - main